+#!/usr/bin/env node
+
+import { describe, it } from "node:test";
+import assert from "node:assert/strict";
+import { QueryContext } from "../src/query-state.js";
+import { deliverToolResults } from "../src/tool-result-delivery.js";
+
+function pending(ctx, id, toolName, resolved) {
+	ctx.pendingToolCalls.set(id, {
+		toolName,
+		resolve: (result) => {
+			ctx.markToolResultResolved(id);
+			resolved.push({ id, result });
+		},
+	});
+}
+
+function text(result) {
+	return result.content.map((block) => block.type === "text" ? block.text : "[image]").join("\n");
+}
+
+describe("active query tool-result delivery", () => {
+	it("supplements waiting results that are present in Pi history but missed by tail extraction", () => {
+		const ctx = new QueryContext();
+		const resolved = [];
+		ctx.recordToolCall("call:one", "read", { path: "one.txt" });
+		ctx.recordToolCall("call:two", "bash", { command: "pwd" });
+		pending(ctx, "call:one", "read", resolved);
+		pending(ctx, "call:two", "bash", resolved);
+
+		const extracted = [{ toolCallId: "call:one", content: [{ type: "text", text: "one" }] }];
+		const messages = [
+			{ role: "user", content: "run both" },
+			{ role: "assistant", content: [{ type: "toolCall", id: "call:one", name: "read" }, { type: "toolCall", id: "call:two", name: "bash" }] },
+			{ role: "toolResult", toolCallId: "call:one", content: "one" },
+			{ role: "assistant", content: [{ type: "text", text: "boundary emitted by host" }] },
+			{ role: "toolResult", toolCallId: "call:two", content: "two" },
+			{ role: "user", content: "interleaved steer" },
+		];
+
+		const outcome = deliverToolResults(ctx, extracted, messages);
+		assert.deepEqual(outcome.unmatchedResultIds, []);
+		assert.deepEqual(outcome.diagnostics.presentButNotExtractedIds, ["call:two"]);
+		assert.deepEqual(outcome.diagnostics.supplementalIds, ["call:two"]);
