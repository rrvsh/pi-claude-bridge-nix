diff -ruN '--exclude=node_modules' a/tests/unit-tool-result-delivery.mjs b/tests/unit-tool-result-delivery.mjs
--- a/tests/unit-tool-result-delivery.mjs	1970-01-01 07:30:00.000000000 +0730
+++ b/tests/unit-tool-result-delivery.mjs	2026-06-27 07:55:38.285723402 +0800
@@ -0,0 +1,99 @@
+#!/usr/bin/env node
+
+import { describe, it } from "node:test";
+import assert from "node:assert/strict";
+import { QueryContext } from "../src/query-state.js";
+import { deliverToolResults } from "../src/tool-result-delivery.js";
+
+function pending(ctx, id, toolName, resolved) {
+	ctx.pendingToolCalls.set(id, {
+		toolName,
+		resolve: (result) => {
+			ctx.markToolResultResolved(id);
+			resolved.push({ id, result });
+		},
+	});
+}
+
+function text(result) {
+	return result.content.map((block) => block.type === "text" ? block.text : "[image]").join("\n");
+}
+
+describe("active query tool-result delivery", () => {
+	it("supplements waiting results that are present in Pi history but missed by tail extraction", () => {
+		const ctx = new QueryContext();
+		const resolved = [];
+		ctx.recordToolCall("call:one", "read", { path: "one.txt" });
+		ctx.recordToolCall("call:two", "bash", { command: "pwd" });
+		pending(ctx, "call:one", "read", resolved);
+		pending(ctx, "call:two", "bash", resolved);
+
+		const extracted = [{ toolCallId: "call:one", content: [{ type: "text", text: "one" }] }];
+		const messages = [
+			{ role: "user", content: "run both" },
+			{ role: "assistant", content: [{ type: "toolCall", id: "call:one", name: "read" }, { type: "toolCall", id: "call:two", name: "bash" }] },
+			{ role: "toolResult", toolCallId: "call:one", content: "one" },
+			{ role: "assistant", content: [{ type: "text", text: "boundary emitted by host" }] },
+			{ role: "toolResult", toolCallId: "call:two", content: "two" },
+			{ role: "user", content: "interleaved steer" },
+		];
+
+		const outcome = deliverToolResults(ctx, extracted, messages);
+		assert.deepEqual(outcome.unmatchedResultIds, []);
+		assert.deepEqual(outcome.diagnostics.presentButNotExtractedIds, ["call:two"]);
+		assert.deepEqual(outcome.diagnostics.supplementalIds, ["call:two"]);
+		assert.deepEqual(resolved.map((item) => item.id), ["call:one", "call:two"]);
+		assert.deepEqual(resolved.map((item) => text(item.result)), ["one", "two"]);
+		assert.equal(ctx.pendingToolCalls.size, 0);
+		assert.equal(ctx.pendingResults.size, 0);
+		assert.deepEqual(ctx.toolResultProgress().unresolvedIds, []);
+	});
+
+	it("does not requeue already-resolved duplicate results from separate callbacks", () => {
+		const ctx = new QueryContext();
+		const resolved = [];
+		ctx.recordToolCall("call:one", "read", { path: "one.txt" });
+		ctx.recordToolCall("call:two", "bash", { command: "pwd" });
+		pending(ctx, "call:one", "read", resolved);
+		pending(ctx, "call:two", "bash", resolved);
+
+		deliverToolResults(ctx, [{ toolCallId: "call:one", content: [{ type: "text", text: "one" }] }], [
+			{ role: "assistant", content: [{ type: "toolCall", id: "call:one", name: "read" }, { type: "toolCall", id: "call:two", name: "bash" }] },
+			{ role: "toolResult", toolCallId: "call:one", content: "one" },
+		]);
+		assert.deepEqual(resolved.map((item) => item.id), ["call:one"]);
+
+		const outcome = deliverToolResults(ctx, [
+			{ toolCallId: "call:one", content: [{ type: "text", text: "one again" }] },
+			{ toolCallId: "call:two", content: [{ type: "text", text: "two" }] },
+		], [
+			{ role: "assistant", content: [{ type: "toolCall", id: "call:one", name: "read" }, { type: "toolCall", id: "call:two", name: "bash" }] },
+			{ role: "toolResult", toolCallId: "call:one", content: "one" },
+			{ role: "user", content: "between callbacks" },
+			{ role: "toolResult", toolCallId: "call:two", content: "two" },
+		]);
+
+		assert.deepEqual(outcome.unmatchedResultIds, []);
+		assert.deepEqual(outcome.diagnostics.skippedDuplicateIds, ["call:one"]);
+		assert.deepEqual(resolved.map((item) => item.id), ["call:one", "call:two"]);
+		assert.equal(ctx.pendingToolCalls.size, 0);
+		assert.equal(ctx.pendingResults.size, 0);
+	});
+
+	it("preserves hard failure behavior for unmatched result ids", () => {
+		const ctx = new QueryContext();
+		const resolved = [];
+		ctx.recordToolCall("call:one", "read", {});
+		pending(ctx, "call:one", "read", resolved);
+
+		const outcome = deliverToolResults(ctx, [{ toolCallId: "call:rogue", content: [{ type: "text", text: "rogue" }] }], [
+			{ role: "assistant", content: [{ type: "toolCall", id: "call:one", name: "read" }] },
+			{ role: "toolResult", toolCallId: "call:rogue", content: "rogue" },
+		]);
+
+		assert.deepEqual(outcome.unmatchedResultIds, ["call:rogue"]);
+		assert.deepEqual(ctx.toolResultProgress().unmatchedResultIds, ["call:rogue"]);
+		assert.equal(ctx.pendingToolCalls.size, 1);
+		assert.deepEqual(resolved, []);
+	});
+});
