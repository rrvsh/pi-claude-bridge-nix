diff -ruN '--exclude=node_modules' a/src/tool-result-delivery.ts b/src/tool-result-delivery.ts
--- a/src/tool-result-delivery.ts	1970-01-01 07:30:00.000000000 +0730
+++ b/src/tool-result-delivery.ts	2026-06-27 07:54:20.397982129 +0800
@@ -0,0 +1,121 @@
+import type { QueryContext } from "./query-state.js";
+import { toolResultToMcpContent, type McpResult } from "./extract-tool-results.js";
+
+export interface PiToolResultMessage {
+	role: string;
+	content?: unknown;
+	toolCallId?: string;
+	isError?: boolean;
+	[key: string]: unknown;
+}
+
+export interface ToolResultDeliveryDiagnostics {
+	extractedIds: string[];
+	contextResultIds: string[];
+	waitingIds: string[];
+	missingFromContextIds: string[];
+	presentButNotExtractedIds: string[];
+	supplementalIds: string[];
+	skippedDuplicateIds: string[];
+}
+
+export interface ToolResultDeliveryOutcome {
+	unmatchedResultIds: string[];
+	diagnostics: ToolResultDeliveryDiagnostics;
+}
+
+function unique(values: Iterable<string | undefined>): string[] {
+	const out: string[] = [];
+	const seen = new Set<string>();
+	for (const value of values) {
+		if (!value || seen.has(value)) continue;
+		seen.add(value);
+		out.push(value);
+	}
+	return out;
+}
+
+function collectContextToolResults(messages: PiToolResultMessage[]): McpResult[] {
+	const results: McpResult[] = [];
+	for (const msg of messages) {
+		if (msg.role !== "toolResult") continue;
+		results.push({
+			content: toolResultToMcpContent(msg.content as string | Array<{ type: string; text?: string; data?: string; mimeType?: string }>),
+			isError: msg.isError,
+			toolCallId: msg.toolCallId,
+		});
+	}
+	return results;
+}
+
+export function diagnoseToolResultExtraction(
+	queryCtx: QueryContext,
+	extractedResults: McpResult[],
+	messages: PiToolResultMessage[],
+): ToolResultDeliveryDiagnostics {
+	const extractedIds = unique(extractedResults.map((result) => result.toolCallId));
+	const contextResults = collectContextToolResults(messages);
+	const contextResultIds = unique(contextResults.map((result) => result.toolCallId));
+	const waitingIds = unique(queryCtx.pendingToolCalls.keys());
+	const contextIdSet = new Set(contextResultIds);
+	const extractedIdSet = new Set(extractedIds);
+	return {
+		extractedIds,
+		contextResultIds,
+		waitingIds,
+		missingFromContextIds: waitingIds.filter((id) => !contextIdSet.has(id)),
+		presentButNotExtractedIds: waitingIds.filter((id) => contextIdSet.has(id) && !extractedIdSet.has(id)),
+		supplementalIds: [],
+		skippedDuplicateIds: [],
+	};
+}
+
+export function deliverToolResults(
+	queryCtx: QueryContext,
+	extractedResults: McpResult[],
+	messages: PiToolResultMessage[],
+	log: (message: string) => void = () => {},
+): ToolResultDeliveryOutcome {
+	const diagnostics = diagnoseToolResultExtraction(queryCtx, extractedResults, messages);
+	const results: McpResult[] = [...extractedResults];
+	const resultIds = new Set(unique(results.map((result) => result.toolCallId)));
+	const contextResults = collectContextToolResults(messages);
+	for (const result of contextResults) {
+		const id = result.toolCallId;
+		if (!id || resultIds.has(id)) continue;
+		if (!queryCtx.hasRecordedToolCall(id)) continue;
+		if (!queryCtx.pendingToolCalls.has(id) && queryCtx.toolResultProgress().deliveredIds.includes(id)) continue;
+		results.push(result);
+		resultIds.add(id);
+		diagnostics.supplementalIds.push(id);
+	}
+
+	const unmatchedResultIds: string[] = [];
+	for (const result of results) {
+		const id = result.toolCallId;
+		if (id && !queryCtx.hasRecordedToolCall(id)) {
+			queryCtx.markToolResultUnmatched(id);
+			unmatchedResultIds.push(id);
+			log(`ERROR: tool result [${id}] has no registered tool_call id; refusing to queue or deliver`);
+			continue;
+		}
+		if (id && !queryCtx.pendingToolCalls.has(id) && queryCtx.toolResultProgress().resolvedIds.includes(id)) {
+			diagnostics.skippedDuplicateIds.push(id);
+			log(`provider: skipping duplicate already-resolved tool result [${id}]`);
+			continue;
+		}
+		queryCtx.markToolResultDelivered(id);
+		if (id && queryCtx.pendingToolCalls.has(id)) {
+			const pending = queryCtx.pendingToolCalls.get(id)!;
+			queryCtx.pendingToolCalls.delete(id);
+			log(`provider: resolving ${pending.toolName} [${id}]${result.isError ? " (error)" : ""}`);
+			pending.resolve(result);
+		} else if (id) {
+			if (!queryCtx.pendingResults.has(id)) queryCtx.pendingResults.set(id, result);
+			log(`provider: queued result [${id}] (${queryCtx.pendingResults.size} pending)`);
+		} else {
+			log("WARNING: tool result without toolCallId, cannot match");
+		}
+	}
+	return { unmatchedResultIds, diagnostics };
+}
